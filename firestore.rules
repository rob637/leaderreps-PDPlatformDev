// Firestore Security Rules - HARDENED
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    // Checks hardcoded admin list first, then dynamic admin lists in metadata
    // All comparisons are case-insensitive (emails converted to lowercase)
    function isAdmin() {
      let isEmailAuth = request.auth != null && request.auth.token != null && 'email' in request.auth.token && request.auth.token.email != null;
      let userEmail = isEmailAuth ? request.auth.token.email.lower() : '';
      let hardcodedAdmins = ['rob@sagecg.com', 'admin@leaderreps.com', 'ryan@leaderreps.com', 'cristina@leaderreps.com', 'jeff@leaderreps.com'];
      
      return isEmailAuth && (
        // 1. Check hardcoded admin list (lowercase comparison)
        userEmail in hardcodedAdmins ||
        // 2. Check metadata/config for dynamic admin list
        (exists(/databases/$(database)/documents/metadata/config) && 
         'adminemails' in get(/databases/$(database)/documents/metadata/config).data &&
         (get(/databases/$(database)/documents/metadata/config).data.adminemails is list && get(/databases/$(database)/documents/metadata/config).data.adminemails.hasAny([userEmail]))) ||
        // 3. Check global/metadata for dynamic admin list (fallback)
        (exists(/databases/$(database)/documents/global/metadata) && 
         'adminemails' in get(/databases/$(database)/documents/global/metadata).data &&
         (get(/databases/$(database)/documents/global/metadata).data.adminemails is list && get(/databases/$(database)/documents/global/metadata).data.adminemails.hasAny([userEmail])))
      );
    }

    // Ascent Revamp WS-4: Ask a Coach responders.
    // Allowlisted via hardcoded list (Christina + Ryan) plus dynamic
    // `metadata/config.askCoachResponders` array. Email comparison is
    // case-insensitive. Admins are always responders.
    function isAskCoachResponder() {
      let isEmailAuth = request.auth != null && request.auth.token != null && 'email' in request.auth.token && request.auth.token.email != null;
      let userEmail = isEmailAuth ? request.auth.token.email.lower() : '';
      let hardcodedResponders = ['cristina@leaderreps.com', 'ryan@leaderreps.com'];
      return isAdmin() || (isEmailAuth && (
        userEmail in hardcodedResponders ||
        (exists(/databases/$(database)/documents/metadata/config) &&
         'askCoachResponders' in get(/databases/$(database)/documents/metadata/config).data &&
         get(/databases/$(database)/documents/metadata/config).data.askCoachResponders is list &&
         get(/databases/$(database)/documents/metadata/config).data.askCoachResponders.hasAny([userEmail]))
      ));
    }

    // Global metadata
    match /global/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Metadata catalogs & Config
    match /metadata/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // LeaderReps Lab — reviewer votes (admin-only)
    match /lab-reviews/{toolId} {
      allow read, write: if isAdmin();
      match /votes/{voterKey} {
        allow read, write: if isAdmin();
      }
    }

    // Config collection (for Feature Flags)
    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // User artifacts
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User modules
    match /modules/{userId}/{document=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    // User profiles and data - Allow admins to list ALL users (collection-level query)
    match /users/{userId} {
      // Allow admins to list/query all users at collection level
      allow list: if isAdmin();
      // Allow individual user reads/writes
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    // User subcollections (action_progress, etc.)
    match /users/{userId}/{subcollection}/{document=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Conversation Simulator — collection-group queries so admins can see all
    // sessions across users from the cost dashboard. Per-document rule above
    // already permits the owner + admins to read/write the docs themselves.
    match /{path=**}/simulator-sessions/{sessionId} {
      allow read: if isAdmin();
    }
    
    // Conditioning notifications - Trainers can write to any user's notifications
    // This allows trainers to push nudges into leader notification queues
    match /users/{userId}/conditioning_notifications/{notifId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if isAdmin();
      allow update: if request.auth != null && (
        request.auth.uid == userId || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Ascent Revamp WS-3: Conditioning Light reps (server-evaluated)
    // Verdicts come from the trusted `evaluateRep` Cloud Function (Admin SDK).
    // NOTE: The wildcard `users/{userId}/{subcollection}` rule above also grants
    // owner write — Firestore unions allow rules. Lockdown of forged verdicts is
    // enforced at the application layer (no client code calls setDoc on reps_light;
    // only the `evaluateRep` callable writes here). If stricter enforcement is
    // needed later, the wildcard must be narrowed to exclude `reps_light`.
    match /users/{userId}/reps_light/{repId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // User data collection (Leader Profile, Assessments, etc.)
    match /user_data/{userId}/{document=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Reppy standalone app user data
    match /reppy_users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    // Reppy invitations (admin can create/manage, users can read their own)
    match /reppy_invitations/{inviteId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Reppy config (admin only)
    match /reppy_config/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Leadership Lab user data
    // Users can read/write their own data, admins can read all
    // SMS-linked users have firebaseAuthUid field that maps to their auth UID
    match /ll-users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || resource.data.firebaseAuthUid == request.auth.uid);
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin() || resource.data.firebaseAuthUid == request.auth.uid);
    }

    // Leadership Lab user subcollections (conversations, leadershipProfile)
    match /ll-users/{userId}/{subcollection}/{document=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || get(/databases/$(database)/documents/ll-users/$(userId)).data.firebaseAuthUid == request.auth.uid);
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin() || get(/databases/$(database)/documents/ll-users/$(userId)).data.firebaseAuthUid == request.auth.uid);
    }

    // Leadership Lab cohorts (admin/facilitator managed)
    match /ll-cohorts/{cohortId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Leadership Lab cohort subcollections (members, alerts)
    match /ll-cohorts/{cohortId}/{subcollection}/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Leadership Lab facilitator data
    match /ll-facilitators/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
    match /ll-facilitators/{userId}/{subcollection}/{document=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Leadership Lab 360 surveys — server-only (Cloud Functions write via Admin SDK)
    match /ll-360surveys/{document=**} {
      allow read, write: if false;
    }

    // Leadership Lab unlock codes — server-only (Cloud Functions manage via Admin SDK)
    match /ll-unlock-codes/{document} {
      allow read, write: if false;
    }

    // Leadership Lab SMS idempotency markers — server-only (webhook dedupe)
    match /ll-processed-sms/{document} {
      allow read, write: if false;
    }

    // Leadership Lab consent / TCPA audit log — append-only, server-written.
    // Admins may read for compliance review. NEVER mutable from client.
    match /ll-consent-events/{document} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Leadership Lab consent dead-letter queue — server-only writes when the
    // primary audit log fails. Admin-readable for manual reconciliation.
    match /ll-consent-events-dlq/{document} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Assessment leads (from Leadership DNA Assessment)
    // Admin read + delete, Cloud Functions write
    match /assessment-leads/{document} {
      allow read: if isAdmin();
      allow delete: if isAdmin();
      allow create, update: if false; // Only Cloud Functions can create/update
    }

    // ROI Calculator leads (from ROI Calculator app)
    // Admin read + delete, Cloud Functions write
    match /roi-calculator-leads/{document} {
      allow read: if isAdmin();
      allow delete: if isAdmin();
      allow create, update: if false; // Only Cloud Functions can create/update
    }

    // Accountability Assessment leads
    // Admin read + isTest toggle + delete, Cloud Functions create
    match /accountability-leads/{document} {
      allow read: if isAdmin();
      allow update: if isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isTest']);
      allow delete: if isAdmin();
      allow create: if false; // Only Cloud Functions can create
    }

    // Accountability Assessment aggregate stats
    // Admin read-only, Cloud Functions write
    match /accountability-stats/{document} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write
    }

    // Manager Accountability Audit leads
    // Admin read + isTest toggle + delete, Cloud Functions create/update
    match /manager-audit-leads/{document} {
      allow read: if isAdmin();
      allow update: if isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isTest']);
      allow delete: if isAdmin();
      allow create: if false; // Only Cloud Functions can create
    }

    // Manager Accountability Audit aggregate stats
    // Admin read-only, Cloud Functions write
    match /manager-audit-stats/{document} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write
    }

    // Leadership Readiness Assessment leads
    // Admin read + delete, Cloud Functions write
    match /readiness-leads/{document} {
      allow read: if isAdmin();
      allow delete: if isAdmin();
      allow create, update: if false; // Only Cloud Functions can create/update
    }

    // Kudos lead magnet — admin-composed, AI-moderated kudos sent to
    // prospects from the admin Sales & Marketing Center. Created directly
    // by authenticated admins (not by a Cloud Function), so admins are
    // allowed to create. Recipients never see Firestore directly.
    match /kudos_leads/{document} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.sentBy.uid == request.auth.uid;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['leadStatus', 'emailDelivered', 'notes']);
      allow delete: if false;
    }

    // Kudos consumer app — anonymous public kudos persisted by the
    // sendKudos Cloud Function. The recipient view goes through the
    // getKudos Cloud Function (sanitized projection), so direct
    // Firestore reads/writes are not permitted for anyone except admins.
    match /kudos_messages/{document} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }
    match /kudos_chains/{document} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }
    match /kudos_sender_counters/{document} {
      allow read, write: if false; // Cloud Functions only (rate limiting)
    }

    // Reinforcing Feedback Kudos lead-magnet — public, NOT anonymous.
    // The gradeRFKudos Cloud Function captures the leader's name + email
    // along with their kudos draft + AI grade. Admins read for follow-up;
    // visitors never read or write directly.
    match /rfkudos_leads/{document} {
      allow read: if isAdmin();
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['leadStatus', 'notes']);
      allow create, delete: if false; // Cloud Function only
    }
    match /rfkudos_sender_counters/{document} {
      allow read, write: if false; // Cloud Function only (rate limiting)
    }

    // Constructive Nudges — anonymous-to-recipient, traceable-to-LeaderReps
    // upward feedback. Written exclusively by the sendNudge Cloud Function
    // (which requires Firebase Auth). Admins can read everything for
    // moderation review; senders can read their own past nudges to populate
    // the composer's "recent" list. Recipients never see Firestore.
    match /nudges_messages/{document} {
      allow read: if isAdmin()
        || (request.auth != null
            && resource.data.senderUid == request.auth.uid);
      allow write: if false; // Cloud Function only
    }
    match /nudge_sender_counters/{document} {
      allow read, write: if false; // Cloud Function only (rate limiting)
    }

    // ---------------------------------------------------------------------
    // LeaderReps Lab — Viral Marketing experiments
    // ---------------------------------------------------------------------

    // Bad Boss Bingo — square pool (public read for the public play page;
    // admin write only). Plays are anonymous, written via Cloud Function.
    match /bingo_squares/{squareId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /bingo_plays/{playId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Function only
    }
    match /bingo_config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Leadership Phrasebook — public read of published phrases (filtered
    // client-side or via a public projection collection in a follow-up).
    // Admin manages all drafts/edits.
    match /phrasebook/{phraseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // State of Leadership Report — admin-managed report metadata + sections.
    // Public read so the /state-of-leadership/{year} landing page can render
    // when status == 'published'. Aggregates and download leads are
    // server-written via Cloud Functions.
    match /reports_sol/{year} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /reports_sol/{year}/aggregates/{document=**} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Function only
    }
    match /reports_sol_downloads/{leadId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Function only
    }

    // Ascent — "Coming Soon" course waitlists (e.g. Lead Self, Lead Team v2)
    // Authenticated user can write/read their own signup; admins can read all.
    match /waitlists/{listId} {
      allow read: if isAdmin();
      allow write: if false;
      match /signups/{userId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
      }
    }
    
    // Public read-only content
    match /public/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    // Content Collections
    match /content_readings/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /content_documents/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /content_videos/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /content_courses/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Unified Content Library (New Architecture)
    match /content/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /content_library/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Daily Reps Library
    match /daily_reps_library/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Skills Taxonomy (New Architecture)
    match /skills/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Media Assets (The Vault)
    match /media_assets/{document} {
      allow read: if request.auth != null;
      // Allow admins to write anywhere
      // Allow users to create assets if they mark themselves as uploader
      allow create: if isAdmin() || (
        request.auth != null && 
        request.resource.data.uploadedBy == request.auth.uid
      );
      // Allow users to update/delete their own assets
      allow update, delete: if isAdmin() || (
        request.auth != null && 
        resource.data.uploadedBy == request.auth.uid
      );
    }

    // Video Series
    match /video_series/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Announcements (admin-posted, user-readable)
    match /announcements/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Video Progress (per-user)
    match /video_progress/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Bug Reports
    match /bug_reports/{document} {
      // Users can create reports linked to their ID
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Users can read/update their own reports, Admins have full access
      allow read, update, delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    // New Content Collections
    match /content_community/{document} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /content_coaching/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Coaching Session Types (Templates)
    match /coaching_session_types/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Coaching Sessions (Scheduled Instances)
    match /coaching_sessions/{document} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      // Allow authenticated users to update ONLY the registration counters
      // (registrationCount and/or spotsLeft) plus updatedAt — needed by the
      // transactional registerForEvent flow in eventsService.js. The hasOnly
      // check ensures they can't modify other fields like title, link, etc.
      allow update: if isAdmin() || (
        request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['registrationCount', 'spotsLeft', 'updatedAt'])
      );
    }

    // Facilitators (coaches, trainers)
    match /facilitators/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /system_lovs/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Coaching Registrations
    // Doc id pattern: `${sessionId}_${userId}` (see eventsService.js).
    match /coaching_registrations/{document} {
      // Allow read when doc doesn't exist OR the requesting user owns it.
      // We also accept ownership inferred from the deterministic docId so
      // legacy documents missing the `userId` field don't block registration.
      allow read: if request.auth != null && (
        resource == null
        || ('userId' in resource.data && request.auth.uid == resource.data.userId)
        || document.matches('.+_' + request.auth.uid)
        || isAdmin()
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && (
        ('userId' in resource.data && request.auth.uid == resource.data.userId)
        || document.matches('.+_' + request.auth.uid)
        || isAdmin()
      );
    }

    // Coaching Waitlist (added May 2026 — Join Waitlist UX)
    // Doc id pattern: `${sessionId}_${userId}` (see communityService.js
    // joinWaitlist). Users can own their entry; trainers/admins can promote.
    match /coaching_waitlist/{document} {
      allow read: if request.auth != null && (
        resource == null
        || ('userId' in resource.data && request.auth.uid == resource.data.userId)
        || document.matches('.+_' + request.auth.uid)
        || isAdmin()
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && (
        ('userId' in resource.data && request.auth.uid == resource.data.userId)
        || document.matches('.+_' + request.auth.uid)
        || isAdmin()
      );
    }

    // Community Session Types (Templates)
    match /community_session_types/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Community Sessions (Scheduled Instances)
    match /community_sessions/{document} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      // Allow authenticated users to update ONLY the registration counters
      // (registrationCount and/or spotsLeft) plus updatedAt — needed by the
      // transactional registerForCommunitySession flow.
      allow update: if isAdmin() || (
        request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['registrationCount', 'spotsLeft', 'updatedAt'])
      );
    }

    // Community Registrations
    // Doc id pattern: `${userId}_${sessionId}` (see communityService.js).
    match /community_registrations/{document} {
      // Allow read when doc doesn't exist OR the requesting user owns it.
      // We also accept ownership inferred from the deterministic docId so
      // legacy documents missing the `userId` field don't block registration.
      allow read: if request.auth != null && (
        resource == null
        || ('userId' in resource.data && request.auth.uid == resource.data.userId)
        || document.matches(request.auth.uid + '_.+')
        || isAdmin()
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && (
        ('userId' in resource.data && request.auth.uid == resource.data.userId)
        || document.matches(request.auth.uid + '_.+')
        || isAdmin()
      );
    }

    // Ascent Revamp WS-4: Ask a Coach
    // Users create + read their own; trainers/responders read all.
    // Additionally: ANSWERED questions are readable by all authenticated users
    // (curated public knowledge base — see Ascent Dashboard "Other Questions").
    match /coach_questions/{document} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId
        || isAskCoachResponder()
        || resource.data.status == 'answered'
      );
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.status == 'open'
        && request.resource.data.responseText == null
        && request.resource.data.responseVideoUrl == null;
      // Users may cancel their own open question; responders may answer/update.
      allow update: if isAskCoachResponder()
        || (request.auth != null
            && request.auth.uid == resource.data.userId
            && resource.data.status == 'open'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt'])
            && request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }

    // System Alerts & Logs
    match /system_alerts/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Notification Rules
    match /notification_rules/{document} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Communication Templates (email, SMS, push notification templates)
    match /communication_templates/{document} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /system_logs/{document=**} {
      // Admins can read all system logs
      allow read: if isAdmin();
      // Any authenticated user can write activity logs (for login, profile complete, etc.)
      allow write: if request.auth != null;
    }

    // Development Plan V1 (Master Plan)
    match /development_plan_v1/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Cohorts
    match /cohorts/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Ascent v3 — Worklist inbox (cohort-scoped issue intake before Open Gym Round)
    // Any authenticated leader may read and create items in their cohort.
    // Updates/deletes restricted to admins.
    match /cohorts/{cohortId}/worklist_inbox/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.submittedBy == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // CONDITIONING LAYER COLLECTIONS
    // ============================================
    
    // Conditioning Configuration Collections - Read by all authenticated, write by admin
    // These define the rep types, categories, situations, prompts, and milestone unlocks
    match /conditioning_rep_types/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /conditioning_categories/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /conditioning_situations/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /conditioning_prompts/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /conditioning_milestone_config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /conditioning_milestones/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /conditioning_quality_dimensions/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /conditioning_coach_prompts/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Conditioning Prep Prompts - Optional prep alignment questions per rep type
    match /conditioning_prep_prompts/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Conditioning Debrief Standards - Pass criteria and coaching prompts for system scoring
    match /conditioning_debrief_standards/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Conditioning Linked Reps - Which RRs auto-create follow-up RRs
    match /conditioning_linked_reps/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Conditioning Complete Config - Questions for completing the conditioning loop
    match /conditioning_complete_config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Conditioning Nudges - Trainers send to leaders
    // Trainers (admins) can create and read all nudges for their cohorts
    // Target users can read their own nudges
    match /conditioning_nudges/{nudgeId} {
      // Admins can list/query all nudges
      allow list: if isAdmin();
      // Individual document reads: admin, target user, or trainer who sent it
      allow get: if request.auth != null && (
        isAdmin() || 
        request.auth.uid == resource.data.targetUserId ||
        request.auth.uid == resource.data.trainerId
      );
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        request.auth != null && 
        request.auth.uid == resource.data.targetUserId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt'])
      );
      allow delete: if isAdmin();
    }
    
    // Conditioning Escalations - Admin/Trainer only
    match /conditioning_escalations/{escalationId} {
      allow read, write: if isAdmin();
    }

    // Follow-Up Reminders - Users can create/read their own, Cloud Functions can update
    match /follow_up_reminders/{reminderId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.userId || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Daily Plan V1 (New Day-by-Day Architecture)
    match /daily_plan_v1/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Daily Plan V2 (May 2026 three-phase model — foundation-content / ascent-content)
    match /daily_plan_v2/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Invitations - allow unauthenticated token lookup for signup flow
    match /invitations/{document} {
      // Allow reading a specific invitation by token (for signup validation)
      // This is safe because tokens are random and single-use
      allow read: if true;
      allow write: if isAdmin();
    }

    // Pending admin promotions — written by Cloud Functions when an invited
    // admin user accepts but the inviter is no longer an admin. Admins read
    // and approve manually.
    match /pending_admin_promotions/{document} {
      allow read, write: if isAdmin();
    }

    // Admin promotion audit trail — append-only via Cloud Functions; admins
    // can read for traceability. Client writes are blocked.
    match /admin_promotion_audit/{document} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Corporate Prospects (Sales Enablement)
    // Only admins can access prospects for sales pipeline management
    match /corporate_prospects/{document} {
      allow read, write: if isAdmin();
    }
    
    // Prospect Activities (Sales Team interaction logs)
    match /prospect_activities/{document} {
      allow read, write: if isAdmin();
    }
    
    // Team Tasks (Sales Team task management)
    match /team_tasks/{document} {
      allow read, write: if isAdmin();
    }
    
    // Outreach Templates (Sales Team email/LinkedIn templates)
    match /outreach_templates/{document} {
      allow read, write: if isAdmin();
    }
    
    // Outreach Sequences (Sales Team multi-step outreach sequences)
    match /outreach_sequences/{document} {
      allow read, write: if isAdmin();
    }
    
    // Outreach Activities (Sales Team activity logs)
    match /outreach_activities/{document} {
      allow read, write: if isAdmin();
    }

    // CRM Accounts (company-level records)
    match /crm_accounts/{document} {
      allow read, write: if isAdmin();
    }

    // CRM Deals (revenue opportunities)
    match /crm_deals/{document} {
      allow read, write: if isAdmin();
    }

    // CRM Audit Logs (server-written via Cloud Functions, read-only for admins)
    match /crm_audit_logs/{document} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // CRM Notifications (per-user inbox; users read their own; CFs/admins write)
    match /crm_notifications/{document} {
      allow read: if request.auth != null && (
        isAdmin() ||
        request.auth.token.email.lower() == resource.data.recipientEmail.lower()
      );
      allow update: if request.auth != null && (
        isAdmin() ||
        request.auth.token.email.lower() == resource.data.recipientEmail.lower()
      );
      allow create, delete: if isAdmin();
    }

    // CRM Workflows (admin-only automation rules)
    match /crm_workflows/{document} {
      allow read, write: if isAdmin();
    }
    
    // Sequence Enrollments (LR-Instantly email automation engine)
    match /sequence_enrollments/{document} {
      allow read, write: if isAdmin();
    }
    
    // Team Settings (Gmail accounts for LR-Instantly)
    match /team_settings/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Admin tool data (UX Audit Lab, etc.)
    match /admin/{docId}/{subcollection}/{subDoc} {
      allow read, write: if isAdmin();
    }
    
    // Book Builder (Sales & Marketing book creation tool)
    match /book/{document} {
      allow read, write: if isAdmin();
    }
    
    match /book_sources/{document} {
      allow read, write: if isAdmin();
    }
    
    match /book_chapters/{document} {
      allow read, write: if isAdmin();
    }
    
    match /book_notes/{document} {
      allow read, write: if isAdmin();
    }
    
    match /books/{document} {
      allow read, write: if isAdmin();
    }

    // LeaderReps Lab — Anonymous Team Pulse (experiment)
    // Admins manage campaigns. Responders can be anonymously authenticated
    // (signInAnonymously) — they may read the campaign meta (to render the
    // question) and create exactly one response document per submission with
    // a strict shape. No reads on responses or insights for non-admins.
    match /team_pulse_campaigns/{campaignId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();

      // Recipients (admin-only — phone numbers and invite tracking)
      match /recipients/{recipientId} {
        allow read, write: if isAdmin();
      }

      // Anonymous responses: any auth user (incl. anonymous) may CREATE one,
      // but the document shape is locked down. Reads are admin-only.
      // 3-question shape: weekKey + scoreEnergy + scoreTrust + scoreTheme +
      // themeId + (optional) text + submittedAt.
      match /responses/{responseId} {
        allow read: if isAdmin();
        allow create: if request.auth != null
          && request.resource.data.keys().hasOnly([
              'weekKey', 'scoreEnergy', 'scoreTrust', 'scoreTheme',
              'themeId', 'text', 'submittedAt'
          ])
          && request.resource.data.weekKey is string
          && request.resource.data.weekKey.size() <= 10
          && request.resource.data.scoreEnergy is number
          && request.resource.data.scoreEnergy >= 1
          && request.resource.data.scoreEnergy <= 5
          && request.resource.data.scoreTrust is number
          && request.resource.data.scoreTrust >= 1
          && request.resource.data.scoreTrust <= 5
          && request.resource.data.scoreTheme is number
          && request.resource.data.scoreTheme >= 1
          && request.resource.data.scoreTheme <= 5
          && request.resource.data.themeId is string
          && request.resource.data.themeId.size() <= 32
          && (!('text' in request.resource.data) || (request.resource.data.text is string && request.resource.data.text.size() <= 500));
        allow update, delete: if isAdmin();
      }

      // AI insights cached per week — admin-only.
      match /insights/{weekKey} {
        allow read, write: if isAdmin();
      }
    }

    // LeaderReps Lab — pulse_leads (Google-style lead-magnet capture)
    // ALL writes happen via Cloud Functions (createPulseLead / attachLeadEmail
    // / addPulseTeamContacts / getLeaderPulseSnapshot / notifyInsightReady).
    // No direct client read or write — the document holds PII (email + token)
    // and the leaderToken is itself a bearer credential.
    match /pulse_leads/{leadId} {
      allow read, write: if isAdmin();
    }

    // LeaderReps Lab — identity_leads (Leadership Identity Statement Builder)
    // ALL writes happen via Cloud Functions (saveIdentityLead).
    // No direct client access — holds PII (email + statement).
    match /identity_leads/{leadId} {
      allow read, write: if isAdmin();
    }

    // Rep Calibration L1 — trainer ratings of completed reps against the
    // engine's automated assessment. Top-level collection, admin-only.
    // Doc id = `${userId}__${repId}` for idempotent upserts. See
    // src/services/calibrationService.js for schema.
    match /rep_calibrations/{calibrationId} {
      allow read, write: if isAdmin();
    }

    // Collection-group access for Rep Calibration queue.
    // `calibrationService.listReps` issues `collectionGroup('conditioning_reps')`
    // to surface every leader's completed reps to the admin calibration UI.
    // Firestore collection-group queries require a rule whose final path
    // segment matches the collection name literally (the wildcard
    // `users/{userId}/{subcollection}/...` rule above only authorizes
    // direct-path reads, not collection-group queries). Admin-only.
    match /{path=**}/conditioning_reps/{repId} {
      allow read: if isAdmin();
    }

    // Content Metrics — silent open/view tracking for social proof
    //
    // Event kinds (validated below):
    //   open       — id `${uid}_${YYYYMMDD}_open`   (per-user-per-day dedup)
    //   first_open — id `${uid}_first_open`          (per-user-forever dedup)
    //   complete   — id `${uid}_complete`            (per-user-forever dedup)
    //   coach_ask  — id `${uid}_${YYYYMMDD}_*_ask`   (no dedup)
    //   share      — id `${uid}_${YYYYMMDD}_*_share` (no dedup)
    //
    // - `content_metrics/{contentId}` aggregate doc: any authed user can read
    //   (so SocialProofBadge can render); only admins (or backend via Admin
    //   SDK) can write. The aggregator Cloud Function uses Admin SDK, bypassing
    //   rules.
    // - Events: users may create their OWN events only (id MUST start with uid)
    //   and the `userId` field in the payload MUST match. Update/delete is
    //   admin-only. Reads are admin-only.
    match /content_metrics/{contentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      match /events/{eventId} {
        allow read: if isAdmin();
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.kind in
               ['open', 'first_open', 'complete', 'coach_ask', 'share']
          && eventId.matches(
               '^' + request.auth.uid +
               '_([0-9]{8}_open|first_open|complete|[0-9]{8}_[a-z0-9]+_(ask|share))$'
             );
        allow update, delete: if isAdmin();
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}