# ---------------------------------------------------------------------------
# Phase 2 (current) — deployed against the LeaderReps PD Platform dev project.
# The browser signs in with Firebase Auth, then calls the `mintSimulatorToken`
# Cloud Function to get a short-lived Gemini Live token. No raw API key here.
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=leaderreps-pd-platform
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Optional — Phase 0 local-only fallback. If set, the simulator skips the
# auth + mint flow and uses this key directly. Never commit a real value.
# ---------------------------------------------------------------------------
# VITE_GEMINI_API_KEY=
