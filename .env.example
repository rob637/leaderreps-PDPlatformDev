# Environment Variables for LeaderReps Platform
# SECURITY: Copy this file to .env.local and fill in real values.
# NEVER commit .env, .env.local, or .env.<env> — they are gitignored.
#
# Real per-environment values live in .env.dev / .env.test / .env.prod
# on each developer's machine. Server-side secrets (Gemini, OpenAI,
# service-account keys) MUST NOT have a VITE_ prefix and MUST be set in
# Google Secret Manager via `firebase functions:secrets:set ...`.

# ---- Firebase Web Config (NOT a secret; identifies the project) ----
# Get these values from Firebase Console > Project Settings > Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ---- Admin Configuration ----
# Comma-separated list of emails granted admin access in the UI. The
# canonical admin allowlist lives in Firestore (metadata/config) and in
# firestore.rules; this VITE_ var is only a UX hint.
VITE_ADMIN_EMAILS=

# ---- Client-side feature flags / tuning ----
VITE_API_TIMEOUT=15000
VITE_MAX_RETRIES=3

# ---- Gemini Proxy URL (deployed Cloud Function) ----
# Example: https://us-central1-<project-id>.cloudfunctions.net/geminiProxy
# The API key itself lives in Secret Manager, not here.
VITE_GEMINI_PROXY_URL=

# Feature Flags
VITE_ENABLE_DEBUG_MODE=false
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# Environment
NODE_ENV=development